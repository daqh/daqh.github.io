<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2QHLH1KGJY"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-2QHLH1KGJY');
    </script>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{{ title }}</title>
    <meta name="title" content="{{ title }}">
    <meta name="author" content="Valerio Di Pasquale">
    <meta name="description" content="{{ description }}">
    <meta name="keywords" content="{{ keywords }}">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <meta name="theme-color" content="#f8f9fa">

    <link rel="canonical" href="{{ canonical }}">
    <meta property="og:type" content="{{ og_type }}">
    <meta property="og:site_name" content="Valerio Di Pasquale">
    <meta property="og:title" content="{{ og_title if og_title else title }}">
    <meta property="og:description" content="{{ og_description if og_description else description }}">
    <meta property="og:url" content="{{ og_url if og_url else canonical }}">
    <meta property="og:image" content="{{ og_image }}">
    <meta property="og:image:alt" content="{{ og_image_alt }}">
    <meta property="og:locale" content="en_US">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ twitter_title if twitter_title else title }}">
    <meta name="twitter:description" content="{{ twitter_description if twitter_description else description }}">
    <meta name="twitter:image" content="{{ twitter_image if twitter_image else og_image }}">

    {% block jsonld %}{% endblock %}

    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="favicon.png" type="image/png">

    <script src="js/jquery.js"></script>

    <link href="bootstrap-5.3.3-dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
    <script src="bootstrap-5.3.3-dist/js/bootstrap.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.min.css">
    <script src="https://kit.fontawesome.com/56b8998b92.js"></script>

    <script src="js/theme-manager.js"></script>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container">
                <a class="navbar-brand" href="#about" aria-label="Go to About section">Valerio Di Pasquale</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="#research">Research</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#education">Education</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#experience">Experience</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#projects">Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#skills">Skills</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#contact">Contact</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container">
        {% block content %}{% endblock %}
    </main>

    <hr>

    <footer class="text-center">
        <p>Valerio Di Pasquale &copy; 2026</p>
    </footer>

    <script>
        const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]');
        const popoverList = [...popoverTriggerList].map(popoverTriggerEl => new bootstrap.Popover(popoverTriggerEl));
    </script>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.1.0/firebase-app.js";
        import { getAnalytics } from "https://www.gstatic.com/firebasejs/11.1.0/firebase-analytics.js";

        const firebaseConfig = {
            apiKey: "AIzaSyBBFU-7f7KD5FRlyIhvOd6_SrYmLwnPu34",
            authDomain: "daqh-github-io.firebaseapp.com",
            projectId: "daqh-github-io",
            storageBucket: "daqh-github-io.firebasestorage.app",
            messagingSenderId: "840051777947",
            appId: "1:840051777947:web:3a8e03b3292b7e1caf413e",
            measurementId: "G-S4M93DNNML"
        };

        const app = initializeApp(firebaseConfig);
        const analytics = getAnalytics(app);
    </script>
</body>
</html>
